# Production Environment Variables Example
# Copy this file to .env and replace the values for production hosting

# -------------------------
# Global & Database
# -------------------------
# The connection string to your PostgreSQL database (e.g. Supabase, Render, Neon, AWS RDS)
DATABASE_URL="postgresql://user:password@hostname:port/dbname?sslmode=require"

# -------------------------
# API Server Configuration
# -------------------------
# Port for the Express API server to run on
PORT="5000"

# Secret used to sign JWTs or Sessions (must be a long random string in production)
SESSION_SECRET="your-super-secure-long-random-string-here"

# Allowed CORS origins for the API (e.g. the production URL of the Next.js storefront)
# e.g., https://your-storefront-domain.com
CORS_ORIGIN="https://your-store.com"

# -------------------------
# Storefront (Next.js) Configuration
# -------------------------
# The public URL of the API server (where browser clients send requests)
# If your API is hosted at api.your-store.com
NEXT_PUBLIC_API_URL="https://api.your-store.com"

# Server-side API origin (used by Next.js during SSR to fetch data from the API)
# This can be the public URL, or an internal cluster URL if hosted on the same network
API_ORIGIN="https://api.your-store.com"
INTERNAL_API_URL="https://api.your-store.com"

# The public URL of the Next.js storefront
NEXT_PUBLIC_SITE_URL="https://your-store.com"
