# ============================================================
# Ilyas Store — Environment Variables
# Copy this file to .env and fill in real values.
# ============================================================

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Render, AWS RDS, etc.)
DATABASE_URL="postgresql://user:password@hostname:5432/dbname?sslmode=require"

# ── API Server ────────────────────────────────────────────────
# Port the Express API server listens on (local dev only — Vercel ignores this)
PORT="5000"

# Secret used to sign JWTs. MUST be a long random string in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="change-me-to-a-64-char-random-string"

# Allowed CORS origin for the API (set to storefront URL in production)
CORS_ORIGIN=""

# ── Storefront (Next.js) ──────────────────────────────────────
# Public URL of the storefront (used for SEO, OG tags, etc.)
NEXT_PUBLIC_SITE_URL="http://localhost:3100"

# Public API URL (browser-side requests from the storefront)
NEXT_PUBLIC_API_URL="http://localhost:5000"

# Internal/server-side API URL (used by Next.js SSR to fetch data)
INTERNAL_API_URL="http://localhost:5000"

# ── Legacy Vite SPA (optional) ────────────────────────────────
# LEGACY_VITE_ORIGIN="http://localhost:3000"

# ── Email (optional) ─────────────────────────────────────────
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# ADMIN_EMAIL="admin@yourstore.com"

# ── Sentry (optional) ────────────────────────────────────────
# SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
# NEXT_PUBLIC_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"

# ── Deployment Tokens (set in CI/CD secrets, not here) ────────
# RENDER_API_KEY=""
# VERCEL_TOKEN=""

# ── Node ──────────────────────────────────────────────────────
NODE_ENV="development"
